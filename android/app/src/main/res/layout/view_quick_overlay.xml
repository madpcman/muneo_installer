<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/root_overlay"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:padding="8dp"
    android:clipChildren="false"
    android:clipToPadding="false">

    <LinearLayout
        android:id="@+id/panel_container"
        android:layout_width="56dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingTop="10dp"
        android:paddingBottom="16dp"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:background="@drawable/bg_overlay_panel_state">

        <Space
            android:layout_width="0dp"
            android:layout_height="6dp" />

        <ImageView
            android:id="@+id/drag_handle"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:layout_marginBottom="6dp"
            android:scaleType="centerInside"
            android:contentDescription="@string/app_name" />

        <LinearLayout
            android:id="@+id/panel_buttons"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal">

            <Space
                android:layout_width="0dp"
                android:layout_height="16dp" />

            <ImageView
                android:id="@+id/btn_main"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_quick_main"
                android:tint="@color/quick_button_icon_tint"
                android:contentDescription="@string/app_name" />

            <Space
                android:layout_width="0dp"
                android:layout_height="16dp" />

            <ImageView
                android:id="@+id/btn_share"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_quick_screen"
                android:tint="@color/quick_button_icon_tint"
                android:contentDescription="@string/overlay_btn_screen" />

            <Space
                android:layout_width="0dp"
                android:layout_height="16dp" />

            <FrameLayout
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginBottom="6dp"
                android:clipChildren="false"
                android:clipToPadding="false">

                <ImageView
                    android:id="@+id/btn_chat"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_quick_chat"
                    android:tint="@color/quick_button_icon_tint"
                    android:contentDescription="@string/overlay_btn_chat" />

                <TextView
                    android:id="@+id/badge_unread"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="end|top"
                    android:layout_marginTop="-4dp"
                    android:layout_marginEnd="-6dp"
                    android:minWidth="18dp"
                    android:minHeight="18dp"
                    android:gravity="center"
                    android:paddingLeft="6dp"
                    android:paddingRight="6dp"
                    android:paddingTop="2dp"
                    android:paddingBottom="2dp"
                    android:textColor="@android:color/white"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:visibility="gone"
                    android:background="@drawable/bg_badge_red" />
            </FrameLayout>
        </LinearLayout>

    </LinearLayout>

</FrameLayout>
