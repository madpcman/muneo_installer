<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/root_lock"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#B4000000">

    <LinearLayout
        android:id="@+id/lock_container"
        android:layout_width="520dp"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:gravity="center_horizontal"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal">

            <!-- <TextView
                android:id="@+id/lock_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/lock_label_bg"
                android:paddingLeft="10dp"
                android:paddingRight="10dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:text="잠시 칠판"
                android:textColor="@android:color/white"
                android:textSize="12sp"
                android:textStyle="bold" /> -->

            <TextView
                android:id="@+id/lock_message"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="10dp"
                android:maxLines="1"
                android:singleLine="true"
                android:text="지금은 선생님께 집중할 시간이에요!"
                android:textColor="@android:color/white"
                android:textSize="24sp"
                android:textStyle="bold" />
        </LinearLayout>

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="290dp"
            android:layout_marginTop="12dp">

            <androidx.cardview.widget.CardView
                android:layout_width="320dp"
                android:layout_height="187dp"
                android:layout_gravity="center_horizontal"
                app:cardElevation="0dp"
                app:cardUseCompatPadding="false"
                app:cardBackgroundColor="@android:color/transparent">

                <ImageView
                    android:id="@+id/lock_board"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:src="@drawable/lock_back_board" />
            </androidx.cardview.widget.CardView>

            <ImageView
                android:id="@+id/lock_teacher"
                android:layout_width="200dp"
                android:layout_height="252dp"
                android:layout_gravity="bottom|center_horizontal"
                android:elevation="10dp"
                android:translationX="-10dp"
                android:scaleType="fitCenter"
                android:src="@drawable/lock_back_teacher" />
        </FrameLayout>
    </LinearLayout>

</FrameLayout>
